<!--
  These 4 Modifiers each grant a flat amount of Max Qi (NpcLingMaxValue, AddV = flat value).
  This part follows the documented Modifier syntax 1:1 (see ACS modding guide -> Modifiers.md),
  so it is the part of this mod I'm confident is correct.
  Duration="-1" makes it permanent (no expiry). MaxStack lets it stack if a disciple eats more than one.
-->
<ModifierDefs><List>

	<Modifier Name="Modifier_MaxQiPill_T1" Type="Normal">
		<DisplayName>木灵丹·一品 效果</DisplayName>
		<Desc>提升修真者灵气上限1,000点。</Desc>
		<MaxStack>0</MaxStack>
		<Duration>-1</Duration>
		<Display>1</Display>
		<Sync>1</Sync>
		<Properties>
			<li Name="NpcLingMaxValue" AddV="1000"/>
		</Properties>
	</Modifier>

	<Modifier Name="Modifier_MaxQiPill_T2" Type="Normal">
		<DisplayName>木灵丹·二品 效果</DisplayName>
		<Desc>提升修真者灵气上限10,000点。</Desc>
		<MaxStack>0</MaxStack>
		<Duration>-1</Duration>
		<Display>1</Display>
		<Sync>1</Sync>
		<Properties>
			<li Name="NpcLingMaxValue" AddV="10000"/>
		</Properties>
	</Modifier>

	<Modifier Name="Modifier_MaxQiPill_T3" Type="Normal">
		<DisplayName>木灵丹·三品 效果</DisplayName>
		<Desc>提升修真者灵气上限100,000点。</Desc>
		<MaxStack>0</MaxStack>
		<Duration>-1</Duration>
		<Display>1</Display>
		<Sync>1</Sync>
		<Properties>
			<li Name="NpcLingMaxValue" AddV="100000"/>
		</Properties>
	</Modifier>

	<Modifier Name="Modifier_MaxQiPill_T4" Type="Normal">
		<DisplayName>木灵丹·四品 效果</DisplayName>
		<Desc>提升修真者灵气上限1,000,000点。</Desc>
		<MaxStack>0</MaxStack>
		<Duration>-1</Duration>
		<Display>1</Display>
		<Sync>1</Sync>
		<Properties>
			<li Name="NpcLingMaxValue" AddV="1000000"/>
		</Properties>
	</Modifier>

</List></ModifierDefs>
